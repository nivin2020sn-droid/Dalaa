# Ignore everything by default to force explicit allowlist — this prevents
# huge unused folders (memory/, test_reports/, etc.) from bloating the build
# context and avoids files leaking into the Docker image.

**/node_modules
**/__pycache__
**/*.pyc
**/*.pyo
**/.DS_Store
**/.git
**/.gitignore
**/.env
**/.env.local
**/.env.*.local
**/.venv
**/venv

# Dev build outputs (will be rebuilt inside the image)
frontend/build
frontend/.eslintcache

# Test artefacts
test_reports/
tests/
**/coverage/

# Emergent / local only
memory/
design_guidelines.json
scripts/
test_result.md

# Logs
*.log
logs/

# IDE
.vscode/
.idea/
*.swp

# Root yarn.lock is only for concurrently (root) — not needed in image
/yarn.lock
/node_modules

# Docs don't need to be in the image
README.md
DEPLOYMENT.md
